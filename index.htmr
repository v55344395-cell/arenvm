  {a:1,b:4,t:"Слабый Рекрут",e:"🧑"},{a:5,b:9,t:"Новобранец Арены",e:"⚔️"},
  {a:10,b:14,t:"Воин Тени",e:"🗡️"},{a:15,b:19,t:"Железный Кулак",e:"✊"},
