let restSec=0,restTotal=0,restInt=null;
const REST_MSGS=[
  "Вдох... Выдох... Сила восстанавливается.",
  "Воин отдыхает — но не расслабляется.",
  "Подготовься к следующему подходу.",
  "Ты заслужил этот отдых, воин.",
  "Дыши глубоко. Следующий подход будет сильнее.",
];
// Camera/Pose
let vEl,cvs,pctx,pDet=null,pActive=false,afId=null,paused=false,frontCam=false;
let frameN=0,repState='up',repCD=false,shHist=[];
// Event timer
let evTmr=null;
// Cutscene typewriter
let csTmr=null;

// ─── AUDIO ENGINE ────────────────────────────────
let aC=null;
function initAudio(){if(!aC)try{aC=new(window.AudioContext||window.webkitAudioContext)();}catch(e){}}
function resumeAudio(){if(aC&&aC.state==='suspended')aC.resume();}

function snd(type){
  initAudio();if(!aC)return;
  resumeAudio();
  const now=aC.currentTime;
  function osc(freq,vol,dur,type='square',freqEnd){
    const o=aC.createOscillator(),g=aC.createGain();
    o.type=type;o.connect(g);g.connect(aC.destination);
    o.frequency.setValueAtTime(freq,now);
    if(freqEnd)o.frequency.exponentialRampToValueAtTime(freqEnd,now+dur*.8);
    g.gain.setValueAtTime(vol,now);g.gain.exponentialRampToValueAtTime(.001,now+dur);
    o.start(now);o.stop(now+dur);
  }
  if(type==='rep'){
    // Sword-hit punch
    osc(180,.12,.08,'square',80);
    osc(440,.08,.05,'sawtooth',220);
  } else if(type==='rep_combo'){
    // Higher pitch for combo
    osc(330,.16,.09,'square',660);
    osc(660,.1,.12,'sine',330);
  } else if(type==='win'){
    // Victory fanfare
    [[261,.18,.28],[329,.16,.35],[392,.14,.42],[523,.18,.55]].forEach(([f,v,t],i)=>{
      const o=aC.createOscillator(),g=aC.createGain();
      o.type='triangle';o.connect(g);g.connect(aC.destination);
      const s=now+i*.13;
      o.frequency.setValueAtTime(f,s);g.gain.setValueAtTime(v,s);
      g.gain.exponentialRampToValueAtTime(.001,s+t);o.start(s);o.stop(s+t);
    });
    // Crowd roar simulation (noise)
    const buf=aC.createBuffer(1,aC.sampleRate*.8,aC.sampleRate);
    const d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=Math.random()*2-1;
    const src=aC.createBufferSource(),gn=aC.createGain(),bf=aC.createBiquadFilter();
    bf.type='bandpass';bf.frequency.value=400;bf.Q.value=.5;
    src.buffer=buf;src.connect(bf);bf.connect(gn);gn.connect(aC.destination);
    gn.gain.setValueAtTime(.04,now+.3);gn.gain.exponentialRampToValueAtTime(.001,now+.8);
    src.start(now+.3);src.stop(now+.9);
  } else if(type==='combo_up'){
    osc(440,.14,.1,'sine',880);
  } else if(type==='tick'){
    osc(900,.05,.04,'sine');
  } else if(type==='breath_in'){
    osc(200,.03,.6,'sine',260);
  } else if(type==='breath_out'){
    osc(260,.03,.6,'sine',180);
  } else if(type==='level_up'){
    [[261,.2,.4],[329,.2,.5],[523,.25,.7],[784,.3,.9]].forEach(([f,v,t],i)=>{
      const o=aC.createOscillator(),g=aC.createGain();
      o.type='sine';o.connect(g);g.connect(aC.destination);
      const s=now+i*.15;
      o.frequency.setValueAtTime(f,s);g.gain.setValueAtTime(v,s);
      g.gain.exponentialRampToValueAtTime(.001,s+t);o.start(s);o.stop(s+t+.1);
    });
  } else if(type==='event_bad'){
    osc(220,.12,.2,'sawtooth',110);
  } else if(type==='event_good'){
    osc(440,.1,.15,'sine',660);
  }
}

// ─── INIT ────────────────────────────────────────
function initApp(){
  loadS();updStreak();refDaily();
  renderNav();renderLB();renderHM();
  showScreen('homeScreen');updHome();
  reqNotif();
  document.addEventListener('touchstart',()=>resumeAudio(),{once:true});
}
function el(id,v){const e=document.getElementById(id);if(e)e.textContent=v;}
function fmtN(n){if(n>=1000)return(n/1000).toFixed(1)+'k';return String(n);}

function loadS(){
  try{const s=localStorage.getItem('arenvm_v5');if(s){const p=JSON.parse(s);S={...S,...p};}}catch(e){}
}
function saveS(){try{localStorage.setItem('arenvm_v5',JSON.stringify(S));}catch(e){}}

function updStreak(){
  const today=new Date().toDateString();
  if(S.lastDate!==today){
    const yest=new Date(Date.now()-86400000).toDateString();
    if(S.lastDate===yest)S.streak++;
    else if(S.lastDate&&S.lastDate!==today)S.streak=0;
    if(S.streak>S.maxStr)S.maxStr=S.streak;
    S.lastDate=today;S.daysActive=(S.daysActive||0)+1;saveS();
  }
}

function refDaily(){
  const today=new Date().toDateString();
  if(S.dailyDate!==today){
    const POOL=[
      {nm:"Удар Рассвета",dc:"С первыми лучами — в бой!",em:"🌅",rp:25},
      {nm:"Страж Ворот",dc:"Удержи рубеж, воин!",em:"🏰",rp:30},
      {nm:"Зов Арены",dc:"Трибуны ждут твоей силы",em:"🎺",rp:20},
      {nm:"Испытание Стали",dc:"Только сильнейший достоин меча",em:"⚔️",rp:35},
      {nm:"Ритуал Силы",dc:"Древний обряд воина",em:"🔮",rp:15},
      {nm:"Последний Бастион",dc:"Защити своих любой ценой",em:"🛡️",rp:40},
    ];
    S.dailyQ=POOL[new Date().getDate()%POOL.length];
    S.dailyProg=0;S.dailyDate=today;
    const wk=getWk();
    if(!S.tourney||S.tourney.week!==wk)S.tourney={week:wk,myPs:0};
    saveS();
  }
}
function getWk(){const d=new Date(),j=new Date(d.getFullYear(),0,1);return d.getFullYear()+'W'+Math.ceil((((d-j)/86400000)+j.getDay()+1)/7);}

// ─── NAV ─────────────────────────────────────────
const NAV_ITEMS=[
  {id:'homeScreen',ic:'🏠',lb:'Главная'},
  {id:'questsScreen',ic:'📜',lb:'Квесты'},
  {id:'trainingScreen',ic:'💪',lb:'Бой'},
  {id:'skillScreen',ic:'🌳',lb:'Навыки'},
  {id:'profileScreen',ic:'⚔️',lb:'Профиль'},
];
function renderNav(){
  ['homeNav','questsNav','trainNav','profileNav','achNav','shopNav','skillNav','guildNav'].forEach(id=>{
    const e=document.getElementById(id);if(!e)return;
    e.innerHTML=NAV_ITEMS.map(n=>`<button class="ni ${curScr===n.id?'on':''}" onclick="showScreen('${n.id}')"><span class="ic">${n.ic}</span><span>${n.lb}</span></button>`).join('')
      +`<button class="ni ${curScr==='achievementsScreen'?'on':''}" onclick="showScreen('achievementsScreen')"><span class="ic">🏆</span><span>Трофеи</span></button>`;
  });
}

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id)?.classList.add('active');
  curScr=id;renderNav();
  if(id==='homeScreen'){updHome();renderLB();renderHM();}
  if(id==='questsScreen')renderQ();
  if(id==='profileScreen')renderProf();
  if(id==='achievementsScreen')renderAch();
  if(id==='shopScreen')renderShop();
  if(id==='skillScreen')renderSkills();
  if(id==='guildScreen')renderGuild();
  if(id==='trainingScreen')initTrain();
}

// ─── HOME UI ─────────────────────────────────────
function updHome(){
  const ti=getTi(S.level);
  el('heroEmoji',ti.e);el('heroTitle',ti.t);el('heroName',S.name);
  el('lvlN',S.level);
  const need=xpN(S.level);
  el('xpNm',S.xp+'/'+need);
  document.getElementById('xpBar').style.width=Math.min(100,S.xp/need*100)+'%';
  el('stT',fmtN(S.total));el('stS',fmtN(S.shards));el('stR',S.streak);
  if(S.dailyQ){
    el('dqN',S.dailyQ.nm);el('dqD',S.dailyQ.dc);el('dqE',S.dailyQ.em);
    el('dqR',S.dailyProg+'/'+S.dailyQ.rp+' отж.');
    document.getElementById('dqBar').style.width=Math.min(100,S.dailyProg/S.dailyQ.rp*100)+'%';
  }
  if(S.activeQ){
    const q=QUESTS.find(q=>q.id===S.activeQ);
    document.getElementById('aqSec').style.display='block';
    if(q){
      el('aqN',q.nm);el('aqE',q.em);el('aqP',S.aqProg+'/'+q.rp+' отж.');
      document.getElementById('aqHP').style.width=(100-Math.min(100,S.aqProg/q.rp*100))+'%';
    }
  } else document.getElementById('aqSec').style.display='none';
}

function goTrain(){showScreen('trainingScreen');}
function goFree(){S.activeQ=null;saveS();showScreen('trainingScreen');}

// ─── LEADERBOARD ─────────────────────────────────
function renderLB(){
  const me={nm:'▶ '+S.name,ps:S.total,lv:S.level,isMe:true};
  const all=[...FAKE_LB,me].sort((a,b)=>b.ps-a.ps).slice(0,7);
  const mdl=['🥇','🥈','🥉'];
  document.getElementById('lbPrev').innerHTML=all.map((e,i)=>`
    <div style="display:flex;align-items:center;gap:.55rem;padding:.55rem .65rem;border-radius:6px;margin-bottom:2px;
      ${i===0?'background:rgba(191,140,48,.1);border:1px solid rgba(191,140,48,.25);':''}
      ${e.isMe?'background:rgba(154,28,28,.1);border:1px solid rgba(154,28,28,.22);':''}">
      <span class="ft" style="width:20px;text-align:center;color:${i<3?'var(--gd2)':'var(--bn2)'};">${mdl[i]||i+1}</span>
      <span style="flex:1;font-size:.82rem;color:${e.isMe?'var(--em2)':'var(--bn)'};">${e.nm}</span>
      <span class="ft" style="font-size:.75rem;color:var(--bn2);">Ур.${e.lv}</span>
      <span class="ft" style="font-size:.82rem;color:var(--gd2);min-width:42px;text-align:right;">${fmtN(e.ps)}</span>
    </div>`).join('');
}

// ─── HEATMAP ─────────────────────────────────────
function renderHM(){
  const g=document.getElementById('hmGrid');if(!g)return;
  let total90=0,activeDays=0;
  const cells=[];
  for(let i=89;i>=0;i--){
    const d=new Date(Date.now()-i*86400000),k=d.toDateString(),v=S.hist?.[k]||0;
    total90+=v;if(v>0)activeDays++;
    let cls='hcell';
    if(v>=100)cls+=' h5';else if(v>=50)cls+=' h4';else if(v>=20)cls+=' h3';else if(v>=5)cls+=' h2';else if(v>=1)cls+=' h1';
    cells.push(`<div class="${cls}" title="${d.toLocaleDateString()}: ${v} отж."></div>`);
  }
  g.innerHTML=cells.join('');
  el('hmStats',activeDays+' активных дней');
}

// ─── QUESTS ──────────────────────────────────────
function renderQ(){
  const filtered=qFilt==='all'?QUESTS:QUESTS.filter(q=>q.tp===qFilt);
  document.getElementById('qList').innerHTML=filtered.map(buildQCard).join('');
}

function buildQCard(q){
  const isActive=S.activeQ===q.id;
  const done=!q.rep&&S.completed.includes(q.id);
  const cdEnd=S.cooldowns[q.id];
  const onCd=cdEnd&&Date.now()<cdEnd;
  const dclr={easy:'#1A7A3A',med:'#BF8C30',hard:'#C04428',boss:'#8800AA'};
  const dnm={easy:'Легко',med:'Средне',hard:'Тяжело',boss:'БОСС'};
  const pct=isActive?Math.min(100,S.aqProg/q.rp*100):0;
  let badge='';
  if(done)badge=`<span class="ft" style="color:var(--gd2);font-size:.62rem;">✓ ЗАВЕРШЁН</span>`;
  else if(onCd){const h=Math.ceil((cdEnd-Date.now())/3600000);badge=`<span class="ft" style="color:var(--bn2);font-size:.62rem;">⏳ ${h}ч</span>`;}
  else if(isActive)badge=`<span class="ft" style="color:var(--em2);font-size:.62rem;animation:pulse 1s infinite;">▶ АКТИВЕН</span>`;
  return `<div class="qcard ${done||onCd?'':'hover-q'}" onclick="${done||onCd?'':'selQ(\''+q.id+'\')'}" style="${done||onCd?'opacity:.5;pointer-events:none;':''}">
    <div class="dbar d${q.df==='easy'?'e':q.df==='med'?'m':q.df==='hard'?'h':q.df==='boss'?'b':'e2'}"></div>
    <div style="padding-left:5px;">
      <div style="display:flex;justify-content:space-between;gap:.45rem;">
        <div style="display:flex;gap:.42rem;align-items:flex-start;flex:1;">
          <span style="font-size:1.55rem;">${q.em}</span>
          <div><div class="ft" style="font-size:.85rem;color:var(--bn);">${q.nm}</div>
          <div style="color:var(--bn2);font-size:.7rem;font-style:italic;">${q.dc}</div></div>
        </div>
        <div style="text-align:right;min-width:62px;">${badge}
          <div class="ft" style="color:var(--em2);font-size:.75rem;margin-top:1px;">${q.rp} отж.</div>
          <div style="font-size:.6rem;color:var(--bn2);">+${q.xp}xp +${q.sh}💎</div>
        </div>
      </div>
      <div style="display:flex;align-items:center;gap:.35rem;margin-top:.32rem;">
        <span style="font-size:.58rem;padding:2px 5px;border-radius:3px;background:${dclr[q.df]}22;color:${dclr[q.df]};font-family:'Cinzel',serif;">${dnm[q.df]}</span>
        ${q.rep?'<span style="font-size:.58rem;padding:2px 5px;border-radius:3px;background:rgba(64,90,200,.1);color:#6090FF;font-family:\'Cinzel\',serif;">ПОВТОР</span>':''}
        ${isActive&&pct>0?`<div style="flex:1;height:3px;background:rgba(0,0,0,.35);border-radius:2px;overflow:hidden;"><div style="height:100%;width:${pct}%;background:var(--em);"></div></div>`:''}
      </div>
    </div>
  </div>`;
}

function fQ(f,btn){
  qFilt=f;
  document.querySelectorAll('.qf').forEach(b=>b.classList.remove('filter-on'));
  btn.classList.add('filter-on');
  renderQ();
}

function selQ(qid){
  const q=QUESTS.find(q=>q.id===qid);if(!q)return;
  S.activeQ=qid;S.aqProg=0;saveS();
  if(q.tp==='boss'&&CS[qid])showCS(qid);
  else{showScreen('trainingScreen');showToast('⚔️ Квест: '+q.nm);}
}

// ─── CUTSCENE (Typewriter) ────────────────────────
function showCS(qid){
  const cs=CS[qid],q=QUESTS.find(q=>q.id===qid);
  el('csEmj',q.em);el('csNm',cs.nm);
  document.getElementById('csov').classList.add('show');
  document.getElementById('csBtn').style.opacity='0';
  document.getElementById('csBtn').style.pointerEvents='none';
  let lineIdx=0;
  function showLine(idx){
    const line=cs.lines[idx];
    const txtEl=document.getElementById('csTxt');
    txtEl.textContent='';
    let charIdx=0;
    clearInterval(csTmr);
    csTmr=setInterval(()=>{
      if(charIdx<line.length){
        txtEl.textContent+=line[charIdx++];
      } else {
        clearInterval(csTmr);
        if(idx<cs.lines.length-1){
          document.getElementById('csBtn').textContent='Далее...';
          document.getElementById('csBtn').style.opacity='1';
          document.getElementById('csBtn').style.pointerEvents='all';
          document.getElementById('csBtn').onclick=()=>{
            document.getElementById('csBtn').style.opacity='0';
            showLine(idx+1);
          };
        } else {
          document.getElementById('csBtn').textContent='⚔️ В БОЙ!';
          document.getElementById('csBtn').style.opacity='1';
          document.getElementById('csBtn').style.pointerEvents='all';
          document.getElementById('csBtn').onclick=()=>{
            document.getElementById('csov').classList.remove('show');
            showScreen('trainingScreen');
            showToast('⚔️ БОСС: '+q.nm+'!');
          };
        }
      }
    },38);
  }
  showLine(0);
}

// ─── TRAINING ────────────────────────────────────
function initTrain(){
  sessReps=0;timerSec=0;clearInterval(timerInt);
  repState='up';shHist=[];
  const q=S.activeQ?QUESTS.find(q=>q.id===S.activeQ):null;
  el('trainLbl',q?q.nm:'Свободная тренировка');
  el('trainTmr','0:00');
  document.getElementById('qpSec').style.display=q?'block':'none';
  document.getElementById('freeSec').style.display=q?'none':'block';
  if(q){
    el('qpTgt','Цель: '+q.rp+' отжиманий');
    el('qpEn',q.dc);el('qpEmj',q.em);
    updQP();
    if(S.skills?.guardian_2){S.shards+=50;S.shEarned+=50;saveS();showToast('🛡️ Бонус Стража: +50💎');}
  }
  // Reset camera UI
  document.getElementById('camPH').style.display='flex';
  document.getElementById('aiOv').style.display='none';
  document.getElementById('manOv').style.display='none';
  el('aiCtr','0');el('manCtr','0');el('freeCtr','0');
  // Combo reset
  resetCombo();updComboUI();
  // Breath
  el('bpmDsp',breathBPM+' /мин');
  if(breathOn)stopBreath();
  el('bTog','▶ Вкл');el('bPhsTxt','Нажми ▶ чтобы начать');el('bCyc','');
  el('bInn','');
  // Random event
  clearTimeout(evTmr);
  document.getElementById('evBanner').style.display='none';
  if(q)schedEv();
  // Timer
  timerInt=setInterval(()=>{
    timerSec++;
    const m=Math.floor(timerSec/60),s=timerSec%60;
    el('trainTmr',m+':'+(s<10?'0':'')+s);
  },1000);
}

function exitTrain(){
  stopCam();clearInterval(timerInt);stopBreath();clearTimeout(evTmr);
  if(sessReps>0){awardReps(sessReps);showToast('💪 Тренировка окончена! +'+sessReps+' отж.');}
  if(S.bestSess<sessReps){S.bestSess=sessReps;saveS();}
  sessReps=0;resetCombo();
  showScreen('homeScreen');
}

// ─── CAMERA ──────────────────────────────────────
async function startCam(front){
  frontCam=front;resumeAudio();
  try{
    const stream=await navigator.mediaDevices.getUserMedia({
      video:{facingMode:front?'user':{ideal:'environment'},width:{ideal:480},height:{ideal:360}}
    });
    vEl=document.getElementById('vfeed');
    cvs=document.getElementById('pcanvas');
    pctx=cvs.getContext('2d');
    vEl.srcObject=stream;
    vEl.onloadedmetadata=()=>{
      cvs.width=vEl.videoWidth;cvs.height=vEl.videoHeight;
      document.getElementById('camWrap').classList.toggle('front',front);
      document.getElementById('camPH').style.display='none';
      document.getElementById('aiOv').style.display='flex';
      loadPose();
    };
  }catch(e){showToast('⚠️ Камера недоступна — ручной режим');useManual();}
}

function flipCam(){stopCam();setTimeout(()=>startCam(!frontCam),350);}

async function loadPose(){
  showToast('🤖 Загружаем AI...');
  try{
    pDet=await poseDetection.createDetector(
      poseDetection.SupportedModels.MoveNet,
      {modelType:poseDetection.movenet.modelType.SINGLEPOSE_LIGHTNING}
    );
    pActive=true;
    showToast('✅ AI-трекинг активен!');
    poseLoop();
  }catch(e){showToast('⚠️ AI не загрузился — используй ручной режим');useManual();}
}

function poseLoop(){if(!pActive||!vEl)return;if(!paused)runPose();afId=requestAnimationFrame(poseLoop);}

frameN=0;
async function runPose(){
  if(++frameN%3!==0)return;
  if(!pDet||!vEl||vEl.readyState<2)return;
  try{
    const poses=await pDet.estimatePoses(vEl);
    if(!poses.length){document.getElementById('aiSt').style.background='#444';return;}
    const pose=poses[0];
    drawSkeleton(pose);detectPU(pose);
    const avg=pose.keypoints.reduce((s,k)=>s+k.score,0)/pose.keypoints.length;
    document.getElementById('aiSt').style.background=avg>.5?'#229090':'#BF8C30';
    el('confT','conf:'+Math.round(avg*100)+'%');
  }catch(e){}
}

function drawSkeleton(pose){
  if(!pctx||!cvs)return;
  pctx.clearRect(0,0,cvs.width,cvs.height);
  const kps=pose.keypoints,g=n=>kps.find(k=>k.name===n);
  const CONN=[['left_shoulder','right_shoulder'],['left_shoulder','left_elbow'],
    ['left_elbow','left_wrist'],['right_shoulder','right_elbow'],['right_elbow','right_wrist'],
    ['left_shoulder','left_hip'],['right_shoulder','right_hip'],['left_hip','right_hip'],
    ['left_hip','left_knee'],['right_hip','right_knee']];
  pctx.strokeStyle='rgba(192,68,40,.75)';pctx.lineWidth=2.5;
  CONN.forEach(([a,b])=>{
    const ka=g(a),kb=g(b);
    if(ka&&kb&&ka.score>.4&&kb.score>.4){pctx.beginPath();pctx.moveTo(ka.x,ka.y);pctx.lineTo(kb.x,kb.y);pctx.stroke();}
  });
  kps.forEach(kp=>{
    if(kp.score<.4)return;
    pctx.beginPath();pctx.arc(kp.x,kp.y,5,0,Math.PI*2);
    pctx.fillStyle=kp.score>.7?'#BF8C30':'rgba(191,140,48,.5)';
    pctx.fill();pctx.strokeStyle='rgba(0,0,0,.4)';pctx.lineWidth=1;pctx.stroke();
  });
}

function detectPU(pose){
  const ls=pose.keypoints.find(k=>k.name==='left_shoulder');
  const rs=pose.keypoints.find(k=>k.name==='right_shoulder');
  if(!ls||!rs||ls.score<.4||rs.score<.4)return;
  const y=(ls.y+rs.y)/2;
  shHist.push(y);if(shHist.length>30)shHist.shift();
  if(shHist.length<10)return;
  const minY=Math.min(...shHist),maxY=Math.max(...shHist),range=maxY-minY;
  if(range<15)return;
  const upT=minY+range*.35,dnT=minY+range*.65;
  if(repState==='up'&&y>dnT){repState='down';el('aiPhs','▼ ВНИЗ');}
  else if(repState==='down'&&y<upT){
    repState='up';el('aiPhs','▲ ВВЕРХ — РЕП!');
    if(!repCD){repCD=true;countRep();setTimeout(()=>repCD=false,480);}
  }
}

function stopCam(){
  pActive=false;
  if(afId)cancelAnimationFrame(afId);
  if(vEl?.srcObject)vEl.srcObject.getTracks().forEach(t=>t.stop()),vEl.srcObject=null;
  document.getElementById('camWrap').classList.remove('front');
  document.getElementById('camPH').style.display='flex';
  document.getElementById('aiOv').style.display='none';
  document.getElementById('manOv').style.display='none';
}

function useManual(){
  document.getElementById('camPH').style.display='none';
  document.getElementById('aiOv').style.display='none';
  document.getElementById('manOv').style.display='flex';
}

function addManRep(){
  countRep();
  const btn=document.getElementById('manBtn');
  btn.style.transform='scale(.91)';setTimeout(()=>btn.style.transform='',110);
}
function togPause(){paused=!paused;el('pauseBtn',paused?'▶ Продолжить':'⏸ Пауза');}

// ─── REP COUNTING ────────────────────────────────
function countRep(){
  sessReps++;resumeAudio();
  // Sound: higher pitch at combo
  snd(comboMult>=2?'rep_combo':'rep');
  showFloatRep();
  // Update all counters
  ['aiCtr','manCtr','freeCtr'].forEach(id=>{
    const e=document.getElementById(id);if(!e)return;
    e.textContent=sessReps;e.classList.remove('pop');void e.offsetWidth;e.classList.add('pop');
  });
  updCombo();
  updQP();
  checkQC();
  // Daily progress
  if(S.dailyQ&&S.dailyProg<S.dailyQ.rp){
    S.dailyProg++;
    if(S.dailyProg>=S.dailyQ.rp){snd('win');showToast('🌅 Ежедневный вызов выполнен! +50💎');S.shards+=50;S.shEarned+=50;}
    saveS();
  }
  // Heatmap
  const today=new Date().toDateString();
  S.hist=S.hist||{};S.hist[today]=(S.hist[today]||0)+1;
}

function showFloatRep(){
  const e=document.createElement('div');e.className='frep';
  const colors=['#F0CC60','#E8B84B','#BF8C30'];
  e.style.color=colors[comboMult>=3?2:comboMult>=2?1:0];
  e.style.fontSize=comboMult>=2?'2.2rem':'1.7rem';
  e.style.textShadow=`0 0 14px ${colors[comboMult>=3?2:0]}`;
  e.textContent=comboMult>=3?'+1 🔥':comboMult>=2?'+1 ⚡':'+1';
  e.style.left=(25+Math.random()*50)+'%';e.style.top='28%';
  document.getElementById('floats').appendChild(e);
  setTimeout(()=>e.remove(),780);
}

// ─── QUEST PROGRESS ─────────────────────────────
function updQP(){
  const q=S.activeQ?QUESTS.find(q=>q.id===S.activeQ):null;if(!q)return;
  const total=S.aqProg+sessReps;
  const pct=Math.min(100,total/q.rp*100);
  el('qpLbl',total+'/'+q.rp);el('qpPct',Math.floor(pct)+'%');
  document.getElementById('qpFill').style.width=(100-pct)+'%';
}

function checkQC(){
  if(!S.activeQ)return;
  const q=QUESTS.find(q=>q.id===S.activeQ);if(!q)return;
  if(S.aqProg+sessReps>=q.rp)completeQ(q);
}

function completeQ(q){
  stopCam();clearInterval(timerInt);stopBreath();clearTimeout(evTmr);
  snd('win');
  const xpM=S.boosts?.xp2&&Date.now()<S.boosts.xp2?2:1;
  const shM=S.boosts?.sh2&&Date.now()<S.boosts.sh2?2:1;
  const bossM=(q.tp==='boss'&&S.skills?.guardian_3)?1.5:1;
  const dungM=(q.tp==='dungeon'&&S.skills?.shadow_3)?2:1;
  const dailyM=(q.tp==='daily'&&S.skills?.shadow_1)?1.5:1;
  awardReps(sessReps);
  const earnXP=Math.floor(q.xp*xpM*bossM*dailyM);
  const earnSh=Math.floor(q.sh*shM*dungM);
  S.xp+=earnXP;S.shards+=earnSh;S.shEarned+=earnSh;
  S.qDone++;S.qcnt=S.qcnt||{};S.qcnt[q.id]=(S.qcnt[q.id]||0)+1;
  if(!q.rep)S.completed.push(q.id);
  if(q.cd)S.cooldowns[q.id]=Date.now()+q.cd*3600000;
  S.activeQ=null;S.aqProg=0;sessReps=0;resetCombo();
  checkLvl();saveS();checkAchs();
  showQCModal(q,earnXP,earnSh);
}

function showQCModal(q,xp,sh){
  el('qcEmj',q.em);el('qcTit',q.nm+' — ПОБЕДА!');el('qcDsc',q.dc);
  document.getElementById('qcRew').innerHTML=
    `<div class="sb"><div class="sv">+${xp}</div><div class="sl">XP</div></div>`+
    `<div class="sb"><div class="sv">+${sh}💎</div><div class="sl">Шарды</div></div>`;
  drawVictory();
  document.getElementById('qcModal').classList.add('open');
}
function closeQC(){document.getElementById('qcModal').classList.remove('open');showScreen('homeScreen');}

function drawVictory(){
  const c=document.getElementById('vcCvs'),cx=c.getContext('2d'),W=c.width,H=c.height;
  const pts=Array.from({length:70},()=>({
    x:W/2,y:H/2,vx:(Math.random()-.5)*10,vy:(Math.random()-.5)*9-2,
    r:Math.random()*3+1,c:['#BF8C30','#C04428','#F0CC60','#fff'][Math.floor(Math.random()*4)],l:1
  }));
  let f=0;
  function draw(){
    cx.clearRect(0,0,W,H);cx.fillStyle='rgba(4,2,0,.12)';cx.fillRect(0,0,W,H);
    pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=.13;p.l-=.014;cx.globalAlpha=Math.max(0,p.l);cx.fillStyle=p.c;cx.beginPath();cx.arc(p.x,p.y,p.r,0,Math.PI*2);cx.fill();});
    cx.globalAlpha=1;
    if(++f<90&&document.getElementById('qcModal').classList.contains('open'))requestAnimationFrame(draw);
  }
  draw();
}

// ─── AWARD REPS ──────────────────────────────────
function awardReps(count){
  if(count<=0)return;
  S.total+=count;
  const shM=S.boosts?.sh2&&Date.now()<S.boosts.sh2?2:1;
  const bM=S.skills?.berserk_3?1.5:S.skills?.berserk_2?1.25:S.skills?.berserk_1?1.1:1;
  const earned=Math.floor(count*.5*shM*bM*comboMult);
  S.shards+=earned;S.shEarned+=earned;
  if(S.tourney)S.tourney.myPs=(S.tourney.myPs||0)+count;
  updStreak();saveS();
}

// ─── COMBO SYSTEM ────────────────────────────────
function resetCombo(){comboMult=1;clearTimeout(comboTmr);clearInterval(comboInt);comboFillPct=100;}

function updCombo(){
  clearTimeout(comboTmr);
  const cdT=S.skills?.guardian_1?COMBO_T*2:COMBO_T;
  if(comboMult<1.5)comboMult=1.5;
  else if(comboMult<2)comboMult=2;
  else{comboMult=3;snd('combo_up');}
  if(comboMult>S.maxCombo){S.maxCombo=comboMult;saveS();}
  comboFillPct=100;
  comboTmr=setTimeout(()=>{comboMult=1;updComboUI();},cdT);
  clearInterval(comboInt);
  comboInt=setInterval(()=>{
    comboFillPct-=100/(cdT/100);if(comboFillPct<0)comboFillPct=0;
    document.getElementById('comboFill').style.width=comboFillPct+'%';
  },100);
  updComboUI();
}

function updComboUI(){
  const d=document.getElementById('comboDsp');if(!d)return;
  const cls={1:'cx1',1.5:'cx15',2:'cx2',3:'cx3'};
  d.className='combodsp '+(cls[comboMult]||'cx1');
  d.textContent='×'+comboMult.toFixed(1);
  const bM=S.skills?.berserk_3?1.5:S.skills?.berserk_2?1.25:S.skills?.berserk_1?1.1:1;
  el('comboSh','+'+Math.ceil(.5*comboMult*bM));
  el('comboHint',comboMult===1?'Жми быстрее для комбо!':comboMult===1.5?'×1.5 — Хорошо!':comboMult===2?'×2.0 — Отлично!':'×3 — БЕРСЕРК! 🔥');
}

// ─── BREATH METRONOME ────────────────────────────
function togBreath(){
  breathOn=!breathOn;
  if(breathOn){startBreath();el('bTog','⏸ Выкл');}
  else{stopBreath();el('bTog','▶ Вкл');el('bPhsTxt','Нажми ▶ чтобы начать');el('bInn','');el('bCyc','');}
}
function chgBPM(d){breathBPM=Math.max(8,Math.min(40,breathBPM+d));el('bpmDsp',breathBPM+' /мин');if(breathOn){stopBreath();startBreath();}}

function startBreath(){breathCyc=0;runBreathPhase('in');}
function stopBreath(){clearTimeout(breathTmr);breathOn=false;}

function runBreathPhase(phase){
  if(!breathOn)return;
  const cycleMs=60000/breathBPM,halfMs=cycleMs/2;
  const circ=document.getElementById('bcirc');
  if(phase==='in'){
    snd('breath_in');
    el('bPhsTxt','↑ Вдох...');el('bInn','↑\nВДОХ');
    circ.style.animation=`breatheIn ${halfMs}ms ease-in-out forwards`;
    circ.style.borderColor='rgba(34,144,144,.7)';
  } else {
    snd('breath_out');
    el('bPhsTxt','↓ Выдох...');el('bInn','↓\nВЫДОХ');
    circ.style.animation=`breatheOut ${halfMs}ms ease-in-out forwards`;
    circ.style.borderColor='rgba(154,28,28,.5)';
    breathCyc++;el('bCyc','Цикл: '+breathCyc);
  }
  breathTmr=setTimeout(()=>runBreathPhase(phase==='in'?'out':'in'),halfMs);
}

// ─── REST TIMER ──────────────────────────────────
function startRest(sec){
  restTotal=sec;restSec=sec;
  document.getElementById('restov').classList.add('show');
  el('restCnt',sec);
  el('restMsg',REST_MSGS[Math.floor(Math.random()*REST_MSGS.length)]);
  document.getElementById('restRing').style.strokeDashoffset=0;
  clearInterval(restInt);
  restInt=setInterval(()=>{
    restSec--;snd('tick');
    el('restCnt',restSec);
    const filled=326.7*(1-restSec/restTotal);
    document.getElementById('restRing').style.strokeDashoffset=filled;
    if(restSec<=0)skipRest();
  },1000);
}
function skipRest(){clearInterval(restInt);document.getElementById('restov').classList.remove('show');showToast('💪 Отдых завершён! Вперёд!');}

// ─── RANDOM EVENTS ───────────────────────────────
function schedEv(){
  if(!S.activeQ)return;
  const delay=18000+Math.random()*25000;
  evTmr=setTimeout(()=>{
    const isShadow=S.skills?.shadow_2;
    const pool=isShadow?EVENTS:EVENTS.filter(e=>e.d<=0||e.bsh);
    const ev=pool[Math.floor(Math.random()*pool.length)];
    showEv(ev);
  },delay);
}

function showEv(ev){
  const q=S.activeQ?QUESTS.find(q=>q.id===S.activeQ):null;if(!q)return;
  snd(ev.d>0?'event_bad':'event_good');
  const ban=document.getElementById('evBanner'),txt=document.getElementById('evTxt');
  txt.textContent=ev.t;txt.style.color=ev.c;
  ban.style.display='block';
  if(ev.d!==0){S.aqProg=Math.max(0,S.aqProg-ev.d);updQP();showToast(ev.t);}
  if(ev.bsh){S.shards+=ev.bsh;S.shEarned+=ev.bsh;saveS();}
  setTimeout(()=>{ban.style.display='none';schedEv();},4000);
}

// ─── LEVEL UP ────────────────────────────────────
function checkLvl(){
  let leveled=false;
  while(S.xp>=xpN(S.level)&&S.level<100){S.xp-=xpN(S.level);S.level++;leveled=true;S.skillPts=(S.skillPts||0)+1;}
  if(leveled)showLvl();
}
function showLvl(){
  snd('level_up');
  const ti=getTi(S.level);
  el('lvlTxt','Уровень '+S.level);el('lvlSub',ti.t);
  el('lvlSP','⭐ +1 очко навыков (всего: '+S.skillPts+')');
  document.getElementById('lvlup').classList.add('show');
}
function closeLvl(){document.getElementById('lvlup').classList.remove('show');updHome();checkAchs();}

// ─── PROFILE ─────────────────────────────────────
function renderProf(){
  const ti=getTi(S.level);
  el('pEmj',ti.e);el('pTit',ti.t);el('pNm',S.name);
  el('pTo',fmtN(S.total));el('pLv',S.level);el('pQu',S.qDone);
  el('pBs',S.bestSess);el('pSt',S.maxStr);el('pSh',fmtN(S.shards));el('pDy',S.daysActive||1);
  const str=Math.min(100,Math.floor(S.total/50));
  const end=Math.min(100,Math.floor(S.total/80));
  const agi=Math.min(100,Math.floor(S.total/100));
  document.getElementById('attBox').innerHTML=[
    {n:'Сила',v:str,c:'#C04428'},{n:'Выносливость',v:end,c:'#BF8C30'},{n:'Ловкость',v:agi,c:'#229090'},
  ].map(a=>`<div style="margin-bottom:.55rem;">
    <div style="display:flex;justify-content:space-between;margin-bottom:2px;">
      <span class="ft" style="font-size:.7rem;color:var(--bn2);">${a.n}</span>
      <span class="ft" style="font-size:.7rem;color:${a.c};">${a.v}</span>
    </div>
    <div class="btr" style="height:4px;"><div style="height:100%;width:${a.v}%;background:${a.c};border-radius:2px;transition:width .8s;"></div></div>
  </div>`).join('');
}

// ─── ACHIEVEMENTS ────────────────────────────────
function checkAchs(){
  ACHS.forEach(a=>{
    if(!S.achs.includes(a.id)&&a.ok(S)){
      S.achs.push(a.id);saveS();
      showToast('🏆 Достижение: '+a.nm+'!');
    }
  });
}
function renderAch(){
  document.getElementById('achList').innerHTML=ACHS.map(a=>{
    const ok=S.achs.includes(a.id);
    return `<div style="display:flex;gap:.65rem;align-items:flex-start;padding:.62rem;border-radius:6px;
      background:${ok?'rgba(38,28,16,.75)':'rgba(0,0,0,.2)'};
      border:1px solid ${ok?'rgba(191,140,48,.3)':'rgba(191,140,48,.07)'};opacity:${ok?1:.5};transition:all .3s;">
      <div style="font-size:1.75rem;filter:${ok?'':'grayscale(1)'};">${a.em}</div>
      <div style="flex:1;">
        <div class="ft" style="font-size:.8rem;color:${ok?'var(--gd2)':'var(--bn2)'};">${a.nm}</div>
        <div style="font-size:.7rem;color:var(--bn2);font-style:italic;">${a.dc}</div>
        ${ok?'<div class="ft" style="font-size:.58rem;color:var(--em2);margin-top:1px;">✓ ПОЛУЧЕНО</div>':''}
      </div>
    </div>`;
  }).join('');
}

// ─── SHOP ────────────────────────────────────────
function renderShop(){
  el('shopSh',S.shards);
  document.getElementById('shopGrid').innerHTML=SHOP.map(it=>{
    const owned=S.purchases.includes(it.id);
    return `<div style="background:linear-gradient(145deg,rgba(30,22,16,.88),rgba(8,6,4,.94));
      border:1px solid ${owned?'rgba(191,140,48,.4)':'var(--br)'};border-radius:8px;
      padding:.82rem;text-align:center;cursor:pointer;transition:all .22s;position:relative;"
      onclick="buyItem('${it.id}')">
      ${owned?'<div class="ft" style="position:absolute;top:4px;right:5px;font-size:.5rem;color:var(--gd2);background:rgba(0,0,0,.5);padding:1px 5px;border-radius:2px;">КУПЛЕНО</div>':''}
      <div style="font-size:2.3rem;margin-bottom:.38rem;">${it.em}</div>
      <div class="ft" style="font-size:.76rem;color:var(--bn);margin-bottom:.18rem;">${it.nm}</div>
      <div style="font-size:.66rem;color:var(--bn2);font-style:italic;margin-bottom:.38rem;">${it.dc}</div>
      ${owned?'<span class="ft" style="color:var(--gd2);font-size:.68rem;">✓ Ваше</span>'
        :`<span class="ft" style="font-size:.8rem;color:var(--gd2);">💎 ${it.cost}</span>`}
    </div>`;
  }).join('');
}

function buyItem(id){
  const it=SHOP.find(i=>i.id===id);if(!it)return;
  if(S.purchases.includes(id)){showToast('Уже куплено!');return;}
  if(S.shards<it.cost){showToast('❌ Недостаточно шардов!');return;}
  S.shards-=it.cost;S.purchases.push(id);
  if(it.bk)S.boosts[it.bk]=Date.now()+86400000;
  saveS();checkAchs();renderShop();el('shopSh',S.shards);
  showToast('✨ Куплено: '+it.nm+'!');
}

// ─── SKILL TREE ──────────────────────────────────
function renderSkills(){
  el('spDsp',S.skillPts||0);
  document.getElementById('skContent').innerHTML=Object.entries(SKILLS).map(([bk,br])=>`
    <div class="rc" style="margin-bottom:.7rem;">
      <div class="rco tl"></div><div class="rco tr"></div>
      <div style="display:flex;align-items:center;gap:.45rem;margin-bottom:.7rem;">
        <span style="font-size:1.5rem;">${br.ic}</span>
        <div class="ft" style="color:${br.col};font-size:.95rem;">${br.nm}</div>
      </div>
      <div style="display:flex;align-items:center;gap:.3rem;margin-bottom:.9rem;">
        ${br.nodes.map((nd,i)=>{
          const owned=S.skills?.[nd.id];
          const reqOk=!nd.req||S.skills?.[nd.req];
          const canBuy=!owned&&reqOk&&(S.skillPts||0)>=nd.cost;
          const cls=owned?'uk':canBuy?'av':'lk';
          return (i>0?`<div class="skline ${S.skills?.[br.nodes[i-1].id]?'on':''}"></div>`:'')
            +`<div class="sknode ${cls}" onclick="${canBuy?`buySkill('${nd.id}','${bk}')`:''}"
              title="${nd.nm}: ${nd.dc} (${nd.cost}★)">
              <span style="font-size:.9rem;">${owned?'✓':i+1}</span>
              <div style="position:absolute;bottom:-18px;left:50%;transform:translateX(-50%);font-size:.5rem;color:${br.col};white-space:nowrap;font-family:'Cinzel',serif;">${nd.nm}</div>
            </div>`;
        }).join('')}
      </div>
      <div style="display:flex;flex-direction:column;gap:.28rem;margin-top:.5rem;">
        ${br.nodes.map(nd=>{
          const owned=S.skills?.[nd.id];
          return `<div style="display:flex;justify-content:space-between;align-items:center;opacity:${owned?1:.45};">
            <span style="font-size:.7rem;color:var(--bn2);font-style:italic;">${nd.nm}: ${nd.dc}</span>
            ${owned?'<span class="ft" style="color:var(--gd2);font-size:.62rem;">✓</span>'
              :`<span class="ft" style="color:var(--bn2);font-size:.62rem;">${nd.cost}★</span>`}
          </div>`;
        }).join('')}
      </div>
    </div>`).join('');
}

function buySkill(nodeId,bk){
  const nd=SKILLS[bk]?.nodes.find(n=>n.id===nodeId);if(!nd)return;
  if((S.skillPts||0)<nd.cost){showToast('❌ Нет очков навыков!');return;}
  S.skillPts-=nd.cost;S.skills=S.skills||{};S.skills[nodeId]=true;
  saveS();checkAchs();renderSkills();el('spDsp',S.skillPts);
  showToast('⭐ Навык открыт: '+nd.nm+'!');
}

// ─── GUILD ───────────────────────────────────────
function renderGuild(){
  const c=document.getElementById('gldContent');
  if(!S.guild){
    c.innerHTML=`
      <div class="rc" style="text-align:center;padding:1.5rem;margin-bottom:.7rem;">
        <div class="rco tl"></div><div class="rco tr"></div>
        <div style="font-size:3rem;margin-bottom:.45rem;">🛡️</div>
        <div class="ft" style="color:var(--gd2);font-size:.95rem;margin-bottom:.25rem;">Ты не состоишь в гильдии</div>
        <div style="color:var(--bn2);font-size:.78rem;font-style:italic;margin-bottom:.9rem;">Вступи или создай гильдию чтобы сражаться вместе</div>
        <input type="text" id="gldNmI" placeholder="Название гильдии..." style="margin-bottom:.45rem;">
        <div style="display:flex;gap:.45rem;margin-top:.4rem;">
          <button class="btn b-blood" onclick="createGld()" style="flex:1;font-size:.8rem;">⚔️ Создать</button>
          <button class="btn b-teal" onclick="joinGld()" style="flex:1;font-size:.8rem;">🛡️ Вступить</button>
        </div>
      </div>
      <div class="div">🔑 КОД ПРИГЛАШЕНИЯ</div>
      <div class="rc" style="padding:.7rem;">
        <div style="color:var(--bn2);font-size:.75rem;font-style:italic;margin-bottom:.45rem;">Введи код чтобы вступить в гильдию друга</div>
        <input type="text" id="gldCodeI" placeholder="Код гильдии (напр: ARENA-1234)">
        <button class="btn b-gold" onclick="joinByCode()" style="width:100%;margin-top:.45rem;font-size:.78rem;">Вступить по коду</button>
      </div>`;
  } else {
    const g=S.guild;
    const code=btoa(g.nm).slice(0,8).toUpperCase();
    const raidNeed=(g.members?.length||1)*100;
    const raidPct=Math.min(100,(g.raidPush||0)/raidNeed*100);
    c.innerHTML=`
      <div class="rc rg" style="margin-bottom:.7rem;">
        <div class="rco tl"></div><div class="rco tr"></div>
        <div style="display:flex;justify-content:space-between;align-items:center;">
          <div>
            <div class="ft" style="color:var(--gd2);font-size:1rem;">${g.nm}</div>
            <div style="color:var(--bn2);font-size:.72rem;">Код: <span class="ft" style="color:var(--tl3);">ARENA-${code}</span></div>
          </div>
          <div style="font-size:2.8rem;">🛡️</div>
        </div>
        <div class="div" style="margin:.55rem 0;">МОЩЬ ГИЛЬДИИ</div>
        <div style="display:flex;gap:.45rem;">
          <div class="sb" style="flex:1;"><div class="sv">${fmtN(g.totalPs||0)}</div><div class="sl">Отжиманий</div></div>
          <div class="sb" style="flex:1;"><div class="sv">${g.members?.length||1}</div><div class="sl">Воинов</div></div>
          <div class="sb" style="flex:1;"><div class="sv">${g.raids||0}</div><div class="sl">Рейдов</div></div>
        </div>
      </div>
      <div class="div">👥 СОСТАВ ГИЛЬДИИ</div>
      ${(g.members||[{nm:S.name,ps:S.total,lv:S.level}]).map(m=>`
        <div style="display:flex;align-items:center;gap:.65rem;padding:.55rem .7rem;border-radius:6px;background:rgba(0,0,0,.28);border:1px solid var(--br);margin-bottom:.35rem;">
          <span style="font-size:1.4rem;">${getTi(m.lv||1).e}</span>
          <div style="flex:1;"><div class="ft" style="font-size:.82rem;color:var(--bn);">${m.nm}</div><div style="font-size:.68rem;color:var(--bn2);">Ур.${m.lv||1} · ${fmtN(m.ps||0)} отж.</div></div>
          <div class="ft" style="font-size:.75rem;color:var(--gd2);">${fmtN(m.ps||0)}</div>
        </div>`).join('')}
      <div style="display:flex;gap:.45rem;margin-bottom:.7rem;margin-top:.45rem;">
        <button class="btn b-ghost" onclick="addFakeMember()" style="flex:1;font-size:.72rem;">+ Пригласить</button>
        <button class="btn b-ghost" onclick="leaveGld()" style="flex:1;font-size:.72rem;color:var(--em2);">Покинуть</button>
      </div>
      <div class="div">⚔️ РЕЙД НА СЛАБОУСА</div>
      <div class="rc rc-ember" style="padding:.7rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem;">
          <div><div class="ft" style="color:var(--em2);font-size:.88rem;">Слабоус (Рейд)</div><div style="color:var(--bn2);font-size:.72rem;">Нужно: ${raidNeed} отж.</div></div>
          <div style="font-size:2rem;">💀</div>
        </div>
        <div class="btr" style="height:6px;margin-bottom:.45rem;"><div class="bhp" style="width:${raidPct}%;height:100%;"></div></div>
        <button class="btn b-blood" onclick="gldRaid()" style="width:100%;font-size:.78rem;">⚔️ Вложить усилие (+10 отж.)</button>
      </div>`;
  }
}

function createGld(){
  const nm=(document.getElementById('gldNmI')?.value||'').trim();
  if(!nm){showToast('Введи название гильдии!');return;}
  S.guild={nm,members:[{nm:S.name,ps:S.total,lv:S.level}],totalPs:S.total,raids:0,raidPush:0};
  saveS();checkAchs();renderGuild();showToast('🛡️ Гильдия "'+nm+'" создана!');
}
function joinGld(){
  const nm=(document.getElementById('gldNmI')?.value||'').trim()||'Братство Кулака';
  S.guild={nm,members:[{nm:S.name,ps:S.total,lv:S.level},{nm:'IronBrother',ps:1200,lv:15},{nm:'ShadowFist',ps:800,lv:11}],totalPs:S.total+2000,raids:3,raidPush:0};
  saveS();checkAchs();renderGuild();showToast('🛡️ Добро пожаловать в "'+nm+'"!');
}
function joinByCode(){
  const code=(document.getElementById('gldCodeI')?.value||'').trim();
  if(!code){showToast('Введи код!');return;}
  S.guild={nm:'Клан_'+code.slice(-4),members:[{nm:S.name,ps:S.total,lv:S.level},{nm:'Союзник_X',ps:500,lv:8}],totalPs:S.total+500,raids:1,raidPush:0};
  saveS();checkAchs();renderGuild();showToast('🛡️ Вступил в клан!');
}
function leaveGld(){if(!confirm('Покинуть гильдию?'))return;S.guild=null;saveS();renderGuild();}
function addFakeMember(){
  if(!S.guild)return;
  const nms=['Ragnar','Bjorn','Siegfried','Aldric','Theron','Valeria','Kira'];
  S.guild.members.push({nm:nms[Math.floor(Math.random()*nms.length)]+'_'+Math.floor(Math.random()*99),ps:Math.floor(Math.random()*2000)+200,lv:Math.floor(Math.random()*30)+5});
  saveS();renderGuild();showToast('👋 Новый участник!');
}
function gldRaid(){
  if(!S.guild)return;
  S.guild.raidPush=(S.guild.raidPush||0)+10;
  S.guild.totalPs=(S.guild.totalPs||0)+10;
  const need=(S.guild.members?.length||1)*100;
  if(S.guild.raidPush>=need){
    S.guild.raids++;S.guild.raidPush=0;
    snd('win');saveS();renderGuild();showToast('🏆 Рейд успешен! Слабоус повержен!');
  } else {saveS();renderGuild();}
}

// ─── WORLD MAP ───────────────────────────────────
function showWorldMap(){
  document.getElementById('worldmap').classList.add('show');
  renderWorldMap();
}
function renderWorldMap(){
  const mc=document.getElementById('mapCanvas');if(!mc)return;
  mc.innerHTML='';
  // Draw connections
  WORLD_REGIONS.forEach((r,i)=>{
    if(i>0){
      const prev=WORLD_REGIONS[i-1];
      const line=document.createElement('div');
      const x1=prev.x,y1=prev.y,x2=r.x,y2=r.y;
      const len=Math.sqrt((x2-x1)**2+(y2-y1)**2);
      const angle=Math.atan2(y2-y1,x2-x1)*180/Math.PI;
      line.style.cssText=`position:absolute;left:${x1}%;top:${y1}%;width:${len}%;height:1px;background:rgba(191,140,48,.2);transform-origin:0 0;transform:rotate(${angle}deg);`;
      mc.appendChild(line);
    }
  });
  WORLD_REGIONS.forEach(r=>{
    const unlocked=S.level>=r.req;
    const div=document.createElement('div');
    div.style.cssText=`position:absolute;left:${r.x}%;top:${r.y}%;transform:translate(-50%,-50%);text-align:center;cursor:${unlocked?'pointer':'default'};`;
    div.innerHTML=`<div style="font-size:1.8rem;${unlocked?'animation:mapPulse 2.5s ease-in-out infinite;':'filter:grayscale(1);opacity:.4;'}">${r.em}</div>
      <div class="ft" style="font-size:.55rem;color:${unlocked?r.col:'var(--bn3)'};margin-top:1px;white-space:nowrap;">${r.nm}</div>
      ${!unlocked?`<div style="font-size:.5rem;color:var(--bn3);font-family:'Cinzel',serif;">Ур.${r.req}</div>`:''}`;
    if(unlocked)div.onclick=()=>{document.getElementById('worldmap').classList.remove('show');showToast('📍 '+r.nm);};
    mc.appendChild(div);
  });
}

// ─── NOTIFICATIONS ───────────────────────────────
function reqNotif(){
  if('Notification'in window&&Notification.permission==='default')Notification.requestPermission();
}

// ─── SAVE / LOAD ─────────────────────────────────
function expSave(){
  try{
    const data=btoa(unescape(encodeURIComponent(JSON.stringify(S))));
    const ta=document.createElement('textarea');ta.value=data;ta.style.cssText='position:fixed;top:-9999px;';
    document.body.appendChild(ta);ta.select();document.execCommand('copy');ta.remove();
    showToast('📋 Код сохранения скопирован!');
  }catch(e){showToast('Ошибка экспорта');}
}
function showImp(){document.getElementById('impModal').classList.add('open');}
function doImport(){
  try{
    const txt=document.getElementById('impTA').value.trim();
    const parsed=JSON.parse(decodeURIComponent(escape(atob(txt))));
    S={...S,...parsed};saveS();
    document.getElementById('impModal').classList.remove('open');
    showToast('✅ Сохранение загружено!');updHome();
  }catch(e){showToast('❌ Неверный код сохранения');}
}
function resetGame(){if(!confirm('Сбросить весь прогресс? Это нельзя отменить.'))return;localStorage.removeItem('arenvm_v5');location.reload();}

// ─── TOAST ───────────────────────────────────────
let _tTmr=null;
function showToast(msg){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  clearTimeout(_tTmr);_tTmr=setTimeout(()=>t.classList.remove('show'),2700);
}

// ─── BOOT ────────────────────────────────────────
window.addEventListener('DOMContentLoaded',()=>{
  if(localStorage.getItem('arenvm_v5'))setTimeout(()=>initApp(),80);
});
</script>
</body>
</html>
