  {a:55,b:64,t:"Чемпион Востока",e:"🏆"},{a:65,b:74,t:"Воевода Арены",e:"👑"},
  {a:75,b:84,t:"Легенда Мощи",e:"🌟"},{a:85,b:94,t:"Гроза Слабоуса",e:"⚡"},
  {a:95,b:99,t:"Покоритель Тьмы",e:"🌑"},{a:100,b:100,t:"Легендарный Титан",e:"🔱"},
];
function getTi(l){return TITLES.find(t=>l>=t.a&&l<=t.b)||TITLES[0];}
function xpN(l){return Math.floor(100*Math.pow(l,1.4));}

